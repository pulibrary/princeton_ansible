# {{ ansible_managed }}
# Rocky Linux mirror locations.
# Consumer repo files (rocky-princeton.repo.j2) use:
#   https://pulmirror.princeton.edu/mirror/rocky/$releasever/$repo/$basearch/os/

location /mirror/rocky/ {
    alias {{ rocky_mirror_root }}/;
    autoindex on;
    autoindex_exact_size off;
    autoindex_localtime on;
}
