apiVersion: v1
kind: PersistentVolume
metadata:
  name: {{ signoz_clickhouse_local_pv_name }}
spec:
  capacity:
    storage: {{ signoz_clickhouse_local_pv_size }}
  volumeMode: Filesystem
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: {{ signoz_clickhouse_local_storage_class }}
  local:
    path: {{ signoz_clickhouse_local_pv_path }}
  nodeAffinity:
    required:
      nodeSelectorTerms:
        - matchExpressions:
            - key: kubernetes.io/hostname
              operator: In
              values:
                - {{ signoz_clickhouse_local_storage_node }}
