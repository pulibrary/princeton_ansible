# {{ ansible_managed }}
# Ubuntu archive mirror locations.

# Direct alias — apt clients configure with /mirror/ubuntu/ as the base URL.
location /mirror/ubuntu/ {
    alias {{ ubuntu_mirror_root }}/;
    autoindex on;
    autoindex_exact_size off;
    autoindex_localtime on;
}

# Common shorthand — point apt sources at https://pulmirror.princeton.edu/ubuntu/
# (without /mirror/ prefix). Redirect to canonical /mirror/ubuntu/.
location /ubuntu/ {
    return 301 /mirror/ubuntu$request_uri;
}
