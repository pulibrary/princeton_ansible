user  {{ openresty_user }};
worker_processes  {{ openresty_worker_processes }};
worker_rlimit_nofile {{ openresty_worker_rlimit_nofile }};

events {
    worker_connections  {{ openresty_worker_connections }};
}

error_log  {{ openresty_error_log_path }};
{% if openresty_syslog_enable %}
error_log  syslog:server=unix:{{ openresty_syslog_socket }},severity={{ openresty_syslog_severity }};
{% endif %}

pid  {{ openresty_pid_path }};

http {
    include       {{ openresty_mime_types }};
    default_type  application/octet-stream;
    sendfile      on;
    keepalive_timeout 65;

    proxy_headers_hash_max_size    {{ openresty_proxy_headers_hash_max_size }};
    proxy_headers_hash_bucket_size {{ openresty_proxy_headers_hash_bucket_size }};

{% if openresty_logger_json_enable %}
    log_format logger-json escape=json '{"source": "nginx","message":"nginx log captured","time": $time_iso8601, "resp_body_size": $body_bytes_sent, "host": "$http_host", "address": "$remote_addr", "request_length": $request_length, "method": "$request_method", "uri": "$request_uri", "status": $status, "user_agent": "$http_user_agent", "resp_time": $request_time, "upstream_addr": "$upstream_addr"}';
{% endif %}

{% for vhost in openresty_vhosts %}
    upstream {{ vhost.upstream.name }} {
        server {{ vhost.upstream.server }};
    }
{% endfor %}
{% if openresty_altcha_enable %}
    upstream altcha_backend {
        server 127.0.0.1:{{ openresty_altcha_port }};
    }
{% endif %}

{% macro proxy_block(vhost) %}
        proxy_pass http://{{ vhost.upstream.name }};
        proxy_buffering          on;
        proxy_busy_buffers_size  512k;
        proxy_buffers            4 512k;
        proxy_buffer_size        256k;
        proxy_http_version       1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
{% endmacro %}

{% for vhost in openresty_vhosts %}
    # ---------- {{ vhost.name }} ----------
    server {
        listen 80;
        server_name {{ vhost.name }};

        location / {
            return 301 https://$server_name$request_uri;
        }

        include {{ openresty_etc_dir }}/conf.d/acme-challenge.conf;
    }

    server {
        listen 443 ssl;
        server_name {{ vhost.name }};

        ssl_certificate     {{ openresty_ssl_cert_dir }}/{{ vhost.ssl_cert }};
        ssl_certificate_key {{ openresty_ssl_key_dir }}/{{ vhost.ssl_key }};
        ssl_session_cache   shared:SSL:1m;
        ssl_prefer_server_ciphers on;
        ssl_protocols       {{ openresty_ssl_protocols }};
        ssl_ciphers         {{ openresty_ssl_ciphers }};

{% if vhost.access_log is defined %}
        access_log {{ openresty_log_dir }}/{{ vhost.access_log }} logger-json;
{% endif %}

        client_max_body_size {{ vhost.client_max_body_size | default('100M') }};

        location / {
{{ proxy_block(vhost) }}
        }

{% if vhost.restrict | default(false) %}
        include {{ openresty_etc_dir }}/conf.d/restrict.conf;
        deny all;
{% endif %}
    }

{% endfor %}
}
