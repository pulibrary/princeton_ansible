#!/usr/bin/env bash
# Managed by Ansible (roles/xrdp)

set -u

LOG="/tmp/xrdp-startwm-${USER:-unknown}-${DISPLAY:-no_display}.log"
exec >>"$LOG" 2>&1
echo "---- $(date -Is) startwm.sh starting: user=${USER:-} display=${DISPLAY:-} uid=$(id -u) ----"

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

export XDG_SESSION_TYPE=x11
export GDK_BACKEND=x11
export DESKTOP_SESSION=xfce
export XDG_CURRENT_DESKTOP=XFCE
export XDG_SESSION_DESKTOP=xfce

uid="$(id -u)"
gid="$(id -g)"

if [[ -d /run/user ]] && [[ ! -d "/run/user/${uid}" ]]; then
  mkdir -p "/run/user/${uid}" || true
fi

if [[ -d "/run/user/${uid}" ]]; then
  chown "${uid}:${gid}" "/run/user/${uid}" || true
  chmod 0700 "/run/user/${uid}" || true
  export XDG_RUNTIME_DIR="/run/user/${uid}"

  mkdir -p "${XDG_RUNTIME_DIR}/gvfs" || true
  chown "${uid}:${gid}" "${XDG_RUNTIME_DIR}/gvfs" || true
  chmod 0700 "${XDG_RUNTIME_DIR}/gvfs" || true
fi

# Disable blanking/DPMS for this XRDP session
xset s off || true
xset s noblank || true
xset -dpms || true

if ! command -v startxfce4 >/dev/null 2>&1; then
  echo "startxfce4 not found. Install xfce4/xfce4-session." >&2
  exit 127
fi

# Start XFCE with a proper per-session dbus
if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
  eval "$(dbus-launch --sh-syntax --exit-with-session)"
  export DBUS_SESSION_BUS_ADDRESS
fi

# xrdp writes the cookie here; make sure xfce4-session can find it
if [[ -z "${XAUTHORITY:-}" ]]; then
  export XAUTHORITY="${HOME}/.Xauthority"
fi
echo "DEBUG: XAUTHORITY=${XAUTHORITY} DISPLAY=${DISPLAY}"

exec xfce4-session
