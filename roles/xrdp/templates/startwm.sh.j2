#!/usr/bin/env bash
# Managed by Ansible (roles/xrdp)

set -u

LOG="/tmp/xrdp-startwm-${USER:-unknown}-${DISPLAY:-no_display}.log"
exec >>"$LOG" 2>&1
echo "---- $(date -Is) startwm.sh starting: user=${USER:-} display=${DISPLAY:-} ----"

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

export XDG_SESSION_TYPE=x11
export GDK_BACKEND=x11
export DESKTOP_SESSION=xfce
export XDG_CURRENT_DESKTOP=XFCE
export XDG_SESSION_DESKTOP=xfce

# If systemd-logind has set this up, keep it; otherwise leave unset
if [[ -z "${XDG_RUNTIME_DIR:-}" ]] && [[ -d "/run/user/$(id -u)" ]]; then
  export XDG_RUNTIME_DIR="/run/user/$(id -u)"
fi

# Disable blanking/DPMS for this XRDP session
xset s off || true
xset s noblank || true
xset -dpms || true

# Start XFCE under a DBus session if possible
if command -v startxfce4 >/dev/null 2>&1; then
  if command -v dbus-run-session >/dev/null 2>&1; then
    exec dbus-run-session -- startxfce4
  fi
  if command -v dbus-launch >/dev/null 2>&1; then
    eval "$(dbus-launch --sh-syntax)"
  fi
  exec startxfce4
fi

echo "startxfce4 not found. Install xfce4/xfce4-session." >&2
exit 127
