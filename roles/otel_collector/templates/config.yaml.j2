# {{ ansible_managed | comment }}

# This file is fully data-driven. Define these in group_vars/project/host_vars:
# - otel_receivers (dict)
# - otel_processors (dict)
# - otel_exporters (dict)
# - otel_service_pipelines (dict)
# - otel_extensions (list)
# Optionally add otel_default_resource_attributes (dict) to merge into processors.resource.
#
# Optional MySQL/MariaDB metrics receiver:
# - otel_mysql_enabled: true
# - otel_mysql_endpoint: "127.0.0.1:3306"
# - otel_mysql_username: "otel"
# - otel_mysql_password: "${env:OTEL_MYSQL_PASSWORD}"
# - otel_mysql_collection_interval: "10s"
# - otel_mysql_initial_delay: "1s"
#
# Optional HTTP synthetic checks:
# - otel_httpcheck_enabled: true
# - otel_httpcheck_component_prefix: "httpcheck"
# - otel_httpcheck_critical_interval: "30s"
# - otel_httpcheck_standard_interval: "300s"
# - otel_httpcheck_tls_interval: "3600s"
# - otel_httpcheck_critical_targets:
#     - name: example
#       endpoint: "https://catalog.princeton.edu/health"
#       method: GET
# - otel_httpcheck_standard_targets: []
# - otel_httpcheck_tls_targets: []

{# Build processors.resource.attributes #}
{% set base_attrs =
  (otel_processors.resource.attributes
    if (otel_processors is defined
        and otel_processors.resource is defined
        and otel_processors.resource.attributes is defined)
    else [])
%}

{% set ns = namespace(extra=[]) %}
{% for k, v in (otel_default_resource_attributes | default({})).items() %}
  {% set _ = ns.extra.append({'action': 'upsert', 'key': k, 'value': v}) %}
{% endfor %}

{% set merged_processors = (otel_processors | default({})) | combine(
  {'resource': {'attributes': base_attrs + ns.extra}},
  recursive=True
) %}

{# add MySQL/MariaDB receiver #}
{% set mysql_receiver = {} %}

{% if otel_mysql_enabled | default(false) | bool %}
  {% set mysql_receiver = {
    'mysql': {
      'endpoint': otel_mysql_endpoint | default('127.0.0.1:3306'),
      'username': otel_mysql_username | default('otel'),
      'password': otel_mysql_password | default('${env:OTEL_MYSQL_PASSWORD}'),
      'collection_interval': otel_mysql_collection_interval | default('10s'),
      'initial_delay': otel_mysql_initial_delay | default('1s')
    }
  } %}

  {% if otel_mysql_statement_events_enabled | default(true) | bool %}
    {% set mysql_receiver = mysql_receiver | combine({
      'mysql': {
        'statement_events': {
          'digest_text_limit': otel_mysql_statement_digest_text_limit | default(120),
          'time_limit': otel_mysql_statement_time_limit | default('24h'),
          'limit': otel_mysql_statement_limit | default(250)
        }
      }
    }, recursive=True) %}
  {% endif %}
{% endif %}

{# Optionally add HTTP synthetic check receivers #}
{% set httpcheck_receivers = {} %}

{% if otel_httpcheck_enabled | default(false) | bool %}
  {% set httpcheck_prefix = otel_httpcheck_component_prefix | default('httpcheck') %}

  {% set critical = namespace(targets=[]) %}
  {% for target in otel_httpcheck_critical_targets | default([]) %}
    {% set _ = critical.targets.append({
      'endpoint': target.endpoint,
      'method': target.method | default('GET')
    }) %}
  {% endfor %}

  {% if critical.targets | length > 0 %}
    {% set httpcheck_receivers = httpcheck_receivers | combine({
      (httpcheck_prefix ~ '/critical'): {
        'collection_interval': otel_httpcheck_critical_interval | default('30s'),
        'targets': critical.targets
      }
    }, recursive=True) %}
  {% endif %}

  {% set standard = namespace(targets=[]) %}
  {% for target in otel_httpcheck_standard_targets | default([]) %}
    {% set _ = standard.targets.append({
      'endpoint': target.endpoint,
      'method': target.method | default('GET')
    }) %}
  {% endfor %}

  {% if standard.targets | length > 0 %}
    {% set httpcheck_receivers = httpcheck_receivers | combine({
      (httpcheck_prefix ~ '/standard'): {
        'collection_interval': otel_httpcheck_standard_interval | default('300s'),
        'targets': standard.targets
      }
    }, recursive=True) %}
  {% endif %}

  {% set tls = namespace(targets=[]) %}
  {% for target in otel_httpcheck_tls_targets | default([]) %}
    {% set _ = tls.targets.append({
      'endpoint': target.endpoint,
      'method': target.method | default('GET')
    }) %}
  {% endfor %}

  {% if tls.targets | length > 0 %}
    {% set httpcheck_receivers = httpcheck_receivers | combine({
      (httpcheck_prefix ~ '/tls'): {
        'collection_interval': otel_httpcheck_tls_interval | default('3600s'),
        'metrics': {
          'httpcheck.tls.cert_remaining': {
            'enabled': true
          }
        },
        'targets': tls.targets
      }
    }, recursive=True) %}
  {% endif %}
{% endif %}

{% set merged_receivers = (otel_receivers | default({}))
  | combine(mysql_receiver, recursive=True)
  | combine(httpcheck_receivers, recursive=True)
%}

{# Start with declared service pipelines #}
{% set merged_service_pipelines = otel_service_pipelines | default({}) %}

{#  Optionally add mysql receiver to metrics pipeline #}
{% if otel_mysql_enabled | default(false) | bool %}
  {% set metrics_pipeline = merged_service_pipelines.metrics | default({}) %}
  {% set metrics_receivers = metrics_pipeline.receivers | default([]) %}

  {% if 'mysql' not in metrics_receivers %}
    {% set metrics_pipeline = metrics_pipeline | combine(
      {'receivers': metrics_receivers + ['mysql']},
      recursive=True
    ) %}
  {% endif %}

  {% set merged_service_pipelines = merged_service_pipelines | combine(
    {'metrics': metrics_pipeline},
    recursive=True
  ) %}
{% endif %}

{# Optionally add httpcheck receivers to metrics pipeline #}
{% if otel_httpcheck_enabled | default(false) | bool %}
  {% set httpcheck_prefix = otel_httpcheck_component_prefix | default('httpcheck') %}
  {% set metrics_pipeline = merged_service_pipelines.metrics | default({}) %}
  {% set metrics_receivers = metrics_pipeline.receivers | default([]) %}
  {% set ns_httpcheck = namespace(receivers=metrics_receivers) %}

  {% if (otel_httpcheck_critical_targets | default([])) | length > 0 and (httpcheck_prefix ~ '/critical') not in ns_httpcheck.receivers %}
    {% set ns_httpcheck.receivers = ns_httpcheck.receivers + [httpcheck_prefix ~ '/critical'] %}
  {% endif %}

  {% if (otel_httpcheck_standard_targets | default([])) | length > 0 and (httpcheck_prefix ~ '/standard') not in ns_httpcheck.receivers %}
    {% set ns_httpcheck.receivers = ns_httpcheck.receivers + [httpcheck_prefix ~ '/standard'] %}
  {% endif %}

  {% if (otel_httpcheck_tls_targets | default([])) | length > 0 and (httpcheck_prefix ~ '/tls') not in ns_httpcheck.receivers %}
    {% set ns_httpcheck.receivers = ns_httpcheck.receivers + [httpcheck_prefix ~ '/tls'] %}
  {% endif %}

  {% set metrics_pipeline = metrics_pipeline | combine(
    {'receivers': ns_httpcheck.receivers},
    recursive=True
  ) %}

  {% set merged_service_pipelines = merged_service_pipelines | combine(
    {'metrics': metrics_pipeline},
    recursive=True
  ) %}
{% endif %}

receivers:
{{ (merged_receivers | default({})) | to_nice_yaml(indent=2) | indent(2, true) }}

processors:
{{ (merged_processors | default({})) | to_nice_yaml(indent=2) | indent(2, true) }}

exporters:
{{ (otel_exporters | default({})) | to_nice_yaml(indent=2) | indent(2, true) }}

service:
  pipelines:
{{ (merged_service_pipelines | default({})) | to_nice_yaml(indent=2) | indent(4, true) }}
  extensions:
{{ (otel_extensions | default([])) | to_nice_yaml(indent=2) | indent(4, true) }}
