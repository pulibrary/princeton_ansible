#jinja2: trim_blocks: True, lstrip_blocks: True
# {{ ansible_managed }}
# Based on the upstream smallstep/certificates hardened unit.
[Unit]
Description=step-ca service
Documentation=https://smallstep.com/docs/step-ca
Documentation=https://smallstep.com/docs/step-ca/certificate-authority-server-production
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=30
StartLimitBurst=3
ConditionFileNotEmpty={{ step_ca_path }}/config/ca.json
ConditionFileNotEmpty={{ step_ca_password_file }}

[Service]
Type=simple
User={{ step_ca_user }}
Group={{ step_ca_group }}
Environment=STEPPATH={{ step_ca_path }}
WorkingDirectory={{ step_ca_path }}
ExecStart={{ step_ca_binary }} config/ca.json --password-file {{ step_ca_password_file | basename }}
ExecReload=/bin/kill --signal HUP $MAINPID
Restart=on-failure
RestartSec=5
TimeoutStopSec=30

; Process capabilities & privileges
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
SecureBits=keep-caps
NoNewPrivileges=yes

; Sandboxing
; Works with YubiKey PIV via pcscd; likely too restrictive for PKCS#11 HSMs.
; Comment out this section for troubleshooting.
ProtectSystem=full
ProtectHome=true
RestrictNamespaces=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
PrivateTmp=true
ProtectClock=true
ProtectControlGroups=true
ProtectKernelTunables=true
ProtectKernelLogs=true
ProtectKernelModules=true
LockPersonality=true
RestrictSUIDSGID=true
RemoveIPC=true
RestrictRealtime=true
PrivateDevices=true
SystemCallFilter=@system-service
SystemCallArchitectures=native
MemoryDenyWriteExecute=true
ReadWritePaths={{ step_ca_path }}/db

[Install]
WantedBy=multi-user.target
